{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "eastus"
    }
  },
  "resources": [
    // [0] NSG for subnet1
    {
      "index": 0,
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "nsg-subnet1",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-HTTP-From-10.0.3.0-24",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "10.0.3.0/24",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },

    // [1] NSG for subnet2
    {
      "index": 1,
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "nsg-subnet2",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowFromWSSubnet",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "1433",
              "sourceAddressPrefix": "10.0.1.0/24",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },

    // [2] NSG for subnet3
    {
      "index": 2,
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "nsg-subnet3",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": []
      }
    },

    // [3] Virtual Network with 3 subnets
    {
      "index": 3,
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "example-vnet",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet1')]",
        "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet2')]",
        "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet3')]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": ["10.0.0.0/16"]
        },
        "subnets": [
          {
            "name": "subnet1",
            "properties": {
              "addressPrefix": "10.0.1.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet1')]"
              }
            }
          },
          {
            "name": "subnet2",
            "properties": {
              "addressPrefix": "10.0.2.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet2')]"
              }
            }
          },
          {
            "name": "subnet3",
            "properties": {
              "addressPrefix": "10.0.3.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg-subnet3')]"
              }
            }
          }
        ]
      }
    }
  ]
}
